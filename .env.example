# 이 파일을 복사해 .env 로 만들고 값을 채운다. .env 는 절대 커밋하지 않는다.

# Sepolia 테스트넷 RPC URL (Alchemy/Infura 등)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# 배포용 테스트 계정의 개인키 (실자금 없는 테스트 계정만 사용)
PRIVATE_KEY=0xYOUR_TEST_PRIVATE_KEY

# Etherscan(Sepolia) 컨트랙트 검증용 API 키
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
